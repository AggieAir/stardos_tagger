				"type": 3,
				"choices": [
					"undefined",
					"manual",
					"auto",
					"aperture priority",
					"shutter priority",
					"creative (biased towards depth of field)",
					"action (biased towards shutter speed)",
					"portrait",
					"landscape"
				],
				"required": false
			},
			{
				"name": "Exif.Photo.ISOSpeed",
				"human_name": "ISO Speed",
