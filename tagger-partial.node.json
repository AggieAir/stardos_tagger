				"type": 0,
				"choices": null,
				"required": false
			},
			{
				"name": "Exif.Photo.MeteringMode",
				"human_name": "Metering Mode",
				"description": "Camera metering mode",
				"type": 3,
				"choices": [
					"unknown",
					"average",
					"center-weighted average",
					"spot",
					"multispot",
					"pattern",
					"partial"
				],
				"required": false
			},
			{
				"name": "Exif.Photo.FocalLength",
				"human_name": "Focal Length",
				"description": "Focal length of camera lens",
