				"description": "Camera manufacturer",
				"type": 2,
				"choices": null,
				"required": true
			},
			{
				"name": "Exif.Image.Model",
				"human_name": "Model",
				"description": "Camera model",
				"type": 2,
				"choices": null,
				"required": true
			},
			{
				"name": "Exif.Photo.ExposureTime",
				"human_name": "Exposure Time",
				"description": "Camera exposure time in seconds",
